# 烟火监控系统配置

# 萤石云访问令牌
FIRE_SMOKE_ACCESS_TOKEN=

# 设备序列号
FIRE_SMOKE_DEVICE_SERIAL=

# 通道号（默认为1）
FIRE_SMOKE_CHANNEL_NO=1

# 项目ID
FIRE_SMOKE_PROJECT_ID=

# 语音告警文件路径
FIRE_SMOKE_VOICE_FILE_PATH=

# 是否启用云端清理（默认为true）
FIRE_SMOKE_ENABLE_CLOUD_CLEANUP=true

# 存储基础路径（默认为./fire_smoke_monitor_results）
FIRE_SMOKE_STORAGE_BASE_PATH=./fire_smoke_monitor_results

# 空间ID
FIRE_SMOKE_SPACE_ID=
