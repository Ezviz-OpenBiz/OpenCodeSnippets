# 宠物监控系统配置

# 萤石云访问令牌
PET_ACCESS_TOKEN=

# 设备序列号
PET_DEVICE_SERIAL=

# 通道号（默认为1）
PET_CHANNEL_NO=1

# 项目ID
PET_PROJECT_ID=

# 语音告警文件路径
PET_VOICE_FILE_PATH=

# 是否启用云端清理（默认为true）
PET_ENABLE_CLOUD_CLEANUP=true

# 存储基础路径（默认为./pet_monitor_results）
PET_STORAGE_BASE_PATH=./pet_monitor_results

# 空间ID
PET_SPACE_ID=
