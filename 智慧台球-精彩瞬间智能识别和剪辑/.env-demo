# 台球监控系统配置

# 萤石云访问令牌
BILLIARDS_ACCESS_TOKEN=at.xxxxxxxxxxxx

# 设备序列号
BILLIARDS_DEVICE_SERIAL=XXXXXXXXX

# 通道号（默认为1）
BILLIARDS_CHANNEL_NO=your_channel_no

# 项目ID
BILLIARDS_PROJECT_ID=XX

# 云录制空间ID
BILLIARDS_SPACE_ID=XX

# 云点播空间ID
BILLIARDS_VOD_SPACE_ID=XX

# 存储基础路径（默认为./billiards_monitor_results）
BILLIARDS_STORAGE_BASE_PATH=./billiards_monitor_results

# 录制时长（秒）
BILLIARDS_RECORD_DURATION_SECONDS=XX